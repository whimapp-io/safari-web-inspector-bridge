{
  "name": "safari-web-inspector-bridge",
  "version": "0.1.0",
  "description": "MCP server bridging Safari Web Inspector for iOS WKWebView automation",
  "type": "module",
  "bin": {
    "safari-web-inspector-bridge": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/whimapp-io/safari-web-inspector-bridge.git"
  },
  "keywords": [
    "mcp",
    "safari",
    "webkit",
    "ios",
    "webview",
    "inspector"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
